    </nav>
    <div class="sidebar-footer">
      <div class="user-chip">
        <div class="user-avatar">DR</div>
        <div><div class="user-name">DRC Admin</div><div class="user-role">Owner view</div></div>
      </div>
    </div>
  </aside>

  <!-- Mobile drawer -->
