let noteCounter = 100;
let currentContact = null;
let activeFilter = 'all';
let searchQuery = '';

function buildProfile(key, targetId) {
  const c = contacts[key];
  if (!c) return '';

  const statusLabel = { complete:'Completed', progress:'In Progress', scheduled:'Scheduled' };
  const statusClass  = { complete:'s-complete', progress:'s-progress', scheduled:'s-scheduled' };

  const jobsHtml = c.jobs.map(j => `
    <div class="job-row">
      <div class="job-row-bar" style="background:${j.color}"></div>
      <div class="job-row-info">
        <div class="job-row-title">${j.title}</div>
        <div class="job-row-meta">${j.date}</div>
      </div>
      <div class="job-row-right">
        <div class="job-row-value">${j.value}</div>
        <div class="job-row-status ${statusClass[j.status]}">${statusLabel[j.status]}</div>
      </div>
    </div>`).join('');

  const ins = c.insurance;
  const insHtml = `
    <div class="ins-grid">
      <div class="ins-field"><div class="ins-label">Carrier</div><div class="ins-value">${ins.carrier || '—'}</div></div>
      <div class="ins-field"><div class="ins-label">Policy #</div><div class="ins-value ins-mono">${ins.policy || '—'}</div></div>
      <div class="ins-field"><div class="ins-label">Claim #</div><div class="ins-value ins-mono">${ins.claim || '—'}</div></div>
      <div class="ins-field"><div class="ins-label">Adjuster</div><div class="ins-value">${ins.adjuster || '—'}</div></div>
      ${ins.adjusterPhone ? `<div class="ins-field"><div class="ins-label">Adjuster phone</div><div class="ins-value"><a href="tel:${ins.adjusterPhone}" style="color:var(--blue);text-decoration:none;">${ins.adjusterPhone}</a></div></div>` : ''}
    </div>`;

  const notesHtml = c.notes.map(n => `
    <div class="note-item" id="${targetId}-${n.id}">
      <div class="note-meta">
        <span class="note-date">${n.date}</span>
        <div class="note-acts">
          <button class="note-btn edit" onclick="editNote('${targetId}-${n.id}')">Edit</button>
          <button class="note-btn del"  onclick="deleteNote('${targetId}-${n.id}')">Delete</button>
        </div>
      </div>
      <div class="note-text" id="${targetId}-${n.id}-text">${n.text}</div>
      <div class="note-edit-wrap" id="${targetId}-${n.id}-edit">
        <textarea class="note-edit-ta" id="${targetId}-${n.id}-ta">${n.text}</textarea>
        <div class="note-edit-foot">
          <button class="btn btn-ghost btn-sm" onclick="cancelEdit('${targetId}-${n.id}')">Cancel</button>
          <button class="btn btn-primary btn-sm" onclick="saveNote('${targetId}-${n.id}')">Save</button>
        </div>
      </div>
    </div>`).join('');

  return `
    <div class="profile-head">
      <div class="profile-avatar" style="background:${c.color}">${c.initials}</div>
      <div style="flex:1;min-width:0;">
        <div class="profile-name">${c.name}</div>
        <div class="profile-type">${c.company ? c.company + ' · ' : ''}${c.type}</div>
        <div class="profile-contact-row"><svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg><a href="tel:${c.phone}">${c.phone}</a></div>
        <div class="profile-contact-row"><svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg><a href="mailto:${c.email}">${c.email}</a></div>
        <div class="profile-contact-row"><svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3"/></svg>${c.address}</div>
      </div>
      <div class="profile-actions">
        <button class="btn btn-ghost btn-sm"><svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>Edit</button>
        <button class="btn btn-primary btn-sm"><svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>New job</button>
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-label">Total value</div>
        <div class="stat-value" style="color:var(--green)">${c.totalValue}</div>
        <div class="stat-sub">Lifetime with DRC</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Jobs</div>
        <div class="stat-value">${c.jobs.length}</div>
        <div class="stat-sub">${c.jobs.filter(j=>j.status==='complete').length} completed</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Lead source</div>
        <div class="stat-value" style="font-size:14px;font-weight:500;margin-top:6px;">${c.source}</div>
      </div>
    </div>

    <div class="section-card">
      <div class="section-card-head">
        <div class="section-card-title">Linked jobs</div>
        <button class="btn btn-primary btn-sm"><svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>New job</button>
      </div>
      <div class="section-card-body" style="padding-top:0;padding-bottom:0;">${jobsHtml || '<div style="padding:16px 0;font-size:13px;color:var(--muted);">No jobs yet</div>'}</div>
    </div>

    <div class="section-card">
      <div class="section-card-head"><div class="section-card-title">Insurance info</div></div>
      <div class="section-card-body">${insHtml}</div>
    </div>

    <div class="section-card">
      <div class="section-card-head">
        <div class="section-card-title">Notes</div>
      </div>
      <div class="section-card-body">
        <div class="add-note-box">
          <textarea class="add-note-ta" placeholder="Add a note..." id="${targetId}-newNote"></textarea>
          <div class="add-note-foot">
            <button class="btn btn-ghost btn-sm" onclick="document.getElementById('${targetId}-newNote').value=''">Clear</button>
            <button class="btn btn-primary btn-sm" onclick="addNote('${targetId}')">Add note</button>
          </div>
        </div>
        <div id="${targetId}-notesList">${notesHtml}</div>
      </div>
    </div>`;
}

function selectContact(card, key) {
  // Highlight card
  document.querySelectorAll('.contact-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  currentContact = key;

  const isMobile = window.innerWidth <= 768;
  if (isMobile) {
    document.getElementById('mobileProfileContent').innerHTML = buildProfile(key, 'mob');
    openMobileProfile();
  } else {
    document.getElementById('profileEmpty').style.display = 'none';
    const content = document.getElementById('profileContent');
    content.style.display = 'block';
    content.innerHTML = buildProfile(key, 'desk');
  }
}

function openMobileProfile() {
  document.getElementById('mobileProfile').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeMobileProfile() {
  document.getElementById('mobileProfile').classList.remove('open');
  document.body.style.overflow = '';
  document.querySelectorAll('.contact-card').forEach(c => c.classList.remove('active'));
}

// Search
function filterContacts(q) {
  searchQuery = q.toLowerCase();
  applyFilters();
}

// Source filter
function setFilter(source, el) {
  document.querySelectorAll('.fpill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  activeFilter = source;
  applyFilters();
}

function applyFilters() {
  const cards = document.querySelectorAll('.contact-card');
  let visible = 0;
  cards.forEach(card => {
    const src = card.dataset.source;
    const text = card.textContent.toLowerCase();
    const matchFilter = activeFilter === 'all' || src === activeFilter;
    const matchSearch = !searchQuery || text.includes(searchQuery);
    const show = matchFilter && matchSearch;
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('contactCount').textContent = visible + ' contact' + (visible !== 1 ? 's' : '');
}

// Notes
function addNote(prefix) {
  const ta = document.getElementById(prefix + '-newNote');
  const text = ta.value.trim();
  if (!text) return;
  const id = prefix + '-n' + noteCounter++;
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) + ' · ' + now.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
  const html = `<div class="note-item" id="${id}">
    <div class="note-meta"><span class="note-date">${dateStr}</span>
    <div class="note-acts"><button class="note-btn edit" onclick="editNote('${id}')">Edit</button><button class="note-btn del" onclick="deleteNote('${id}')">Delete</button></div></div>
    <div class="note-text" id="${id}-text">${text.replace(/</g,'&lt;')}</div>
    <div class="note-edit-wrap" id="${id}-edit">
      <textarea class="note-edit-ta" id="${id}-ta">${text.replace(/</g,'&lt;')}</textarea>
      <div class="note-edit-foot"><button class="btn btn-ghost btn-sm" onclick="cancelEdit('${id}')">Cancel</button><button class="btn btn-primary btn-sm" onclick="saveNote('${id}')">Save</button></div>
    </div>
  </div>`;
  document.getElementById(prefix + '-notesList').insertAdjacentHTML('afterbegin', html);
  ta.value = '';
}
function editNote(id) {
  document.getElementById(id+'-text').style.display='none';
  const w = document.getElementById(id+'-edit');
  w.classList.add('open'); w.style.display='block';
  document.getElementById(id+'-ta').focus();
}
function cancelEdit(id) {
  document.getElementById(id+'-text').style.display='';
  const w = document.getElementById(id+'-edit');
  w.classList.remove('open'); w.style.display='none';
}
function saveNote(id) {
  const txt = document.getElementById(id+'-ta').value.trim();
  if (!txt) return;
  document.getElementById(id+'-text').textContent = txt;
  cancelEdit(id);
}
function deleteNote(id) {
  const el = document.getElementById(id);
  el.style.opacity='0'; el.style.transition='opacity 0.18s';
  setTimeout(()=>el.remove(), 200);
}

// Drawer
function openDrawer() { document.getElementById('drawer').classList.add('open'); document.getElementById('overlay').classList.add('open'); document.body.style.overflow='hidden'; }
function closeDrawer() { document.getElementById('drawer').classList.remove('open'); document.getElementById('overlay').classList.remove('open'); document.body.style.overflow=''; }
</script>
